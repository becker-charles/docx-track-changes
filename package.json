{
	"name": "docx-track-changes",
	"version": "0.1.2",
	"description": "Interact with tracked changes in .docx files",
	"keywords": [
		"docx",
		"documents",
		"ooxml",
		"revision",
		"changes",
		"tracked"
	],
	"license": "MIT",
	"author": "Charles H. Becker",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/becker-charles/docx-track-changes.git"
	},
	"bugs": {
		"url": "https://github.com/becker-charles/docx-track-changes/issues"
	},
	"homepage": "https://github.com/becker-charles/docx-track-changes#readme",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint src tests",
		"lint:fix": "eslint src tests --fix",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"fast-xml-parser": "^4.3.0",
		"jszip": "^3.10.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@types/node": "^20.0.0",
		"@vitest/coverage-v8": "^1.0.0",
		"docx": "^9.6.1",
		"eslint": "^9.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.4.0",
		"typescript-eslint": "^8.0.0",
		"vitest": "^1.0.0"
	}
}
